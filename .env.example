# PostgreSQL
# Homebrew PostgreSQL (default): use your macOS username, no password
DATABASE_URL="postgresql://YOUR_MAC_USERNAME@localhost:5432/helloweirdough_crm?schema=public"
# Docker Compose instead:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/helloweirdough_crm?schema=public"

# Server
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
CLIENT_URL=http://localhost:5173

# Client (Vite)
VITE_API_URL=http://localhost:4000/api
VITE_SOCKET_URL=http://localhost:4000

# Twilio (optional in dev — logs to console if missing)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1234567890
